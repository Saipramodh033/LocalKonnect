# Django
SECRET_KEY=django-insecure-change-this-in-production-xyz123456789
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Database
DATABASE_NAME=localkonnect_db
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_HOST=db
DATABASE_PORT=5432

# Redis
REDIS_URL=redis://redis:6379/0

# Gemini AI
GEMINI_API_KEY=your-gemini-api-key-here

# Email Configuration
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# JWT Settings
JWT_ACCESS_TOKEN_LIFETIME=60
JWT_REFRESH_TOKEN_LIFETIME=1440

# AWS S3 (Optional - for production file storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1

# Security
CORS_ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Trust Score Parameters
TRUST_DECAY_FACTOR=0.5
TRUST_MIN_WEIGHT=0.05
TRUST_VERIFIED_BONUS=0.5
TRUST_TIME_DECAY_LAMBDA=0.01
TRUST_SMOOTHING_K=5
TRUST_MAX_EXPERIENCE_BONUS=15

# Fraud Detection
FRAUD_MAX_TRUSTS_PER_HOUR=5
FRAUD_MAX_TRUSTS_PER_DAY=20
FRAUD_PATTERN_SCAN_INTERVAL=30
